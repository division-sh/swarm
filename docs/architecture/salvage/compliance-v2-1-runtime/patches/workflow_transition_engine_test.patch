+func TestFactoryPipelineCoordinator_OperatingGuardsAcceptPersistedEvidence(t *testing.T) {
+	_, db, _ := testutil.StartPostgres(t)
+	pc := NewFactoryPipelineCoordinator(NewEventBus(InMemoryEventStore{}), db)
+	ctx := context.Background()
+	verticalID := uuid.NewString()
+
+	if _, err := db.ExecContext(ctx, `
+		INSERT INTO verticals (id, name, slug, geography, stage, mode, created_at, updated_at)
+		VALUES ($1::uuid, 'Evidence Ops', 'evidence-ops', 'us', 'full_speccing', 'operating', now(), now())
+	`, verticalID); err != nil {
+		t.Fatalf("insert vertical: %v", err)
+	}
+
+	pc.recordWorkflowEvidence(ctx, verticalID, "spec_validation_passed", map[string]any{"validation_notes": "approved"})
+	outcome, ok := pc.applyWorkflowEventTransition(ctx, events.Event{
+		ID:         uuid.NewString(),
+		Type:       events.EventType("spec.approved"),
+		VerticalID: verticalID,
+		Payload:    mustJSON(map[string]any{"vertical_id": verticalID}),
+	})
+	if !ok || outcome.Transition.Name != "full_speccing_to_building" {
+		t.Fatalf("expected persisted spec evidence transition, got ok=%v outcome=%+v", ok, outcome)
+	}
+
+	pc.recordWorkflowEvidence(ctx, verticalID, "qa_validation_passed", map[string]any{"test_summary": "green"})
+	outcome, ok = pc.applyWorkflowEventTransition(ctx, events.Event{
+		ID:         uuid.NewString(),
+		Type:       events.EventType("build_complete"),
+		VerticalID: verticalID,
+		Payload:    mustJSON(map[string]any{"vertical_id": verticalID}),
+	})
+	if !ok || outcome.Transition.Name != "building_to_pre_launch" {
+		t.Fatalf("expected persisted qa evidence transition, got ok=%v outcome=%+v", ok, outcome)
+	}
+
+	pc.recordWorkflowEvidence(ctx, verticalID, "deploy_approved", map[string]any{"feedback": "approved"})
+	outcome, ok = pc.applyWorkflowEventTransition(ctx, events.Event{
+		ID:         uuid.NewString(),
+		Type:       events.EventType("launch_ready"),
+		VerticalID: verticalID,
+		Payload:    mustJSON(map[string]any{"vertical_id": verticalID}),
+	})
+	if !ok || outcome.Transition.Name != "pre_launch_to_launched" {
+		t.Fatalf("expected persisted deploy evidence transition, got ok=%v outcome=%+v", ok, outcome)
+	}
+}
