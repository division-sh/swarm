+func TestFactoryPipelineCoordinator_ApplyWorkflowEventTransition_OperatingLifecycle(t *testing.T) {
+	_, db, _ := testutil.StartPostgres(t)
+	pc := NewFactoryPipelineCoordinator(NewEventBus(InMemoryEventStore{}), db)
+	ctx := context.Background()
+	verticalID := uuid.NewString()
+
+	if _, err := db.ExecContext(ctx, `
+		INSERT INTO verticals (id, name, slug, geography, stage, mode, created_at, updated_at)
+		VALUES ($1::uuid, 'Clinic OS', 'clinic-os', 'us', 'full_speccing', 'operating', now(), now())
+	`, verticalID); err != nil {
+		t.Fatalf("insert vertical: %v", err)
+	}
+
+	for _, tc := range []struct {
+		eventType events.EventType
+		payload   map[string]any
+		wantID    string
+		wantStage string
+	}{
+		{eventType: events.EventType("spec.approved"), payload: map[string]any{"status": "passed"}, wantID: "full_speccing_to_building", wantStage: "building"},
+		{eventType: events.EventType("build_complete"), payload: map[string]any{"qa_passed": true}, wantID: "building_to_pre_launch", wantStage: "pre_launch"},
+		{eventType: events.EventType("launch_ready"), payload: map[string]any{"decision": "approved"}, wantID: "pre_launch_to_launched", wantStage: "launched"},
+		{eventType: events.EventType("opco.steady_state_reached"), payload: map[string]any{}, wantID: "launched_to_operating", wantStage: "operating"},
+		{eventType: events.EventType("opco.growth_triggered"), payload: map[string]any{}, wantID: "operating_to_expanding", wantStage: "expanding"},
+		{eventType: events.EventType("opco.growth_stabilized"), payload: map[string]any{}, wantID: "expanding_to_operating", wantStage: "operating"},
+	} {
+		payload := tc.payload
+		if payload == nil {
+			payload = map[string]any{}
+		}
+		payload["vertical_id"] = verticalID
+		outcome, ok := pc.applyWorkflowEventTransition(ctx, events.Event{
+			ID:         uuid.NewString(),
+			Type:       tc.eventType,
+			VerticalID: verticalID,
+			Payload:    mustJSON(payload),
+		})
+		if !ok {
+			t.Fatalf("expected %s transition", tc.eventType)
+		}
+		if outcome.Transition.Name != tc.wantID {
+			t.Fatalf("unexpected transition for %s: %+v", tc.eventType, outcome.Transition)
+		}
+		assertVerticalStage(t, ctx, db, verticalID, tc.wantStage)
+	}
+}
+
+func TestFactoryPipelineCoordinator_ApplyWorkflowEventTransition_TeardownRequiresHumanDecision(t *testing.T) {
+	_, db, _ := testutil.StartPostgres(t)
+	pc := NewFactoryPipelineCoordinator(NewEventBus(InMemoryEventStore{}), db)
+	ctx := context.Background()
+	verticalID := uuid.NewString()
+
+	if _, err := db.ExecContext(ctx, `
+		INSERT INTO verticals (id, name, slug, geography, stage, mode, created_at, updated_at)
+		VALUES ($1::uuid, 'Teardown Ops', 'teardown-ops', 'us', 'operating', 'operating', now(), now())
+	`, verticalID); err != nil {
+		t.Fatalf("insert vertical: %v", err)
+	}
+
+	if _, ok := pc.applyWorkflowEventTransition(ctx, events.Event{
+		ID:         uuid.NewString(),
+		Type:       events.EventType("opco.teardown_requested"),
+		VerticalID: verticalID,
+		Payload:    mustJSON(map[string]any{"vertical_id": verticalID}),
+	}); ok {
+		t.Fatal("expected non-human opco.teardown_requested to fail guard evaluation")
+	}
+	assertVerticalStage(t, ctx, db, verticalID, "operating")
+
+	outcome, ok := pc.applyWorkflowEventTransition(ctx, events.Event{
+		ID:          uuid.NewString(),
+		Type:        events.EventType("opco.teardown_requested"),
+		SourceAgent: "human",
+		VerticalID:  verticalID,
+		Payload:     mustJSON(map[string]any{"vertical_id": verticalID, "mailbox_decision_id": uuid.NewString()}),
+	})
+	if !ok {
+		t.Fatal("expected human opco.teardown_requested to transition")
+	}
+	if outcome.Transition.Name != "operating_to_winding_down" {
+		t.Fatalf("unexpected transition: %+v", outcome.Transition)
+	}
+	assertVerticalStage(t, ctx, db, verticalID, "winding_down")
+	instance, ok, err := pc.workflowStore.Load(ctx, verticalID)
+	if err != nil || !ok {
+		t.Fatalf("load workflow instance: ok=%v err=%v", ok, err)
+	}
+	if !truthyMetadataFlag(instance.Metadata["action_begin_teardown_executed"]) {
+		t.Fatalf("expected begin_teardown metadata, got %+v", instance.Metadata)
+	}
+}
