+func TestFactoryPipelineCoordinator_ExecuteWorkflowAction_EmitSpecValidationRequested(t *testing.T) {
+	_, db, _ := testutil.StartPostgres(t)
+	pc := NewFactoryPipelineCoordinator(NewEventBus(InMemoryEventStore{}), db)
+	ctx := context.Background()
+	verticalID := uuid.NewString()
+	emitted := []events.Event{}
+	ctx = context.WithValue(ctx, pipelineEmitCollectorKey{}, &emitted)
+
+	if _, err := db.ExecContext(ctx, `
+		INSERT INTO verticals (id, name, slug, geography, stage, mode, created_at, updated_at)
+		VALUES ($1::uuid, 'Spec Validation', 'spec-validation', 'us', 'branding', 'factory', now(), now())
+	`, verticalID); err != nil {
+		t.Fatalf("insert vertical: %v", err)
+	}
+
+	ok := pc.executeWorkflowAction(ctx, workflowTriggerContext{
+		Event: events.Event{
+			Type:       events.EventType("brand.candidates_ready"),
+			VerticalID: verticalID,
+			Payload: mustJSON(map[string]any{
+				"vertical_id": verticalID,
+				"final_spec": map[string]any{
+					"name":        "Spec Validation",
+					"description": "Automates appeal packaging",
+				},
+			}),
+		},
+		State: WorkflowState{VerticalID: verticalID, Stage: StageBranding},
+	}, "emit_spec_validation_requested")
+	if !ok {
+		t.Fatal("expected emit_spec_validation_requested action to execute")
+	}
+	if len(emitted) != 1 || string(emitted[0].Type) != "spec.validation_requested" {
+		t.Fatalf("expected spec.validation_requested emit, got %+v", emitted)
+	}
+	payload := parsePayloadMap(emitted[0].Payload)
+	spec := parsePayloadMap(mustJSON(payload["spec_content"]))
+	if strings.TrimSpace(asString(payload["vertical_id"])) != verticalID {
+		t.Fatalf("expected vertical_id=%s, got payload=%v", verticalID, payload)
+	}
+	finalSpec := parsePayloadMap(mustJSON(spec["final_spec"]))
+	if strings.TrimSpace(asString(finalSpec["name"])) != "Spec Validation" {
+		t.Fatalf("expected final spec payload to be forwarded, got %v", payload)
+	}
+}
