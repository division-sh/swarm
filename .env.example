# Copy to .env for explicit Postgres-backed Docker Compose runs. Plain local
# `swarm run --contracts ...` uses SQLite at .swarm/dev.db by default and does
# not need this file. Do not commit real secrets.

# Required when starting the Compose orchestrator service because its API binds
# inside the container on 0.0.0.0. Plain loopback-only local serve uses the
# built-in dev token with bearer auth still enabled.
SWARM_API_TOKEN=replace-with-random-token

# Required only when starting the Compose orchestrator service with a contract
# bundle mounted at /opt/swarm/contracts.
SWARM_CONTRACTS_HOST_DIR=/absolute/path/to/your/contracts

# Optional fallback for plain local `swarm serve` when --data and
# workspace.data_source are not set. Do not combine this with
# SWARM_WORKSPACE_VOLUMES_FROM.
SWARM_WORKSPACE_DATA_SOURCE=

# Backend credentials. Set the one required by the backend you run.
CLAUDE_CODE_OAUTH_TOKEN=
ANTHROPIC_API_KEY=
OPENAI_COMPATIBLE_API_KEY=

# Optional MCP/tool-gateway token for deployments that expose that surface.
SWARM_TOOL_GATEWAY_TOKEN=
