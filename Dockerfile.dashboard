FROM node:20-alpine AS build
WORKDIR /app

COPY internal/dashboard/ui/package.json internal/dashboard/ui/package-lock.json ./
RUN npm ci

COPY internal/dashboard/ui/src ./src
RUN npm run build

FROM nginx:1.27-alpine
COPY internal/dashboard/assets/dashboard.html /usr/share/nginx/html/dashboard/index.html
COPY --from=build /app/dist/dashboard.app.js /usr/share/nginx/html/dashboard/assets/dashboard.app.js
COPY --from=build /app/dist/dashboard.css /usr/share/nginx/html/dashboard/assets/dashboard.css
COPY deploy/nginx/dashboard.conf /etc/nginx/conf.d/default.conf
